include ../widgets/page/banner
if theme.brevity.enable
  - var feed = site.data.brevity || []
  - var perPage = (theme.brevity.strip > 0) ? theme.brevity.strip : 30
  - var totalPages = Math.max(1, Math.ceil(feed.length / perPage))
  - var currentPage = page.brevity_page || 1
  - var sliced = page.brevity_items || feed.slice((currentPage - 1) * perPage, currentPage * perPage)
  - var envId = theme.twikoo.envId
  - var region = theme.twikoo.region || ''
  - var twikooOption = theme.twikoo.option || {}
  - var twikooCdn = url_for(theme.cdn.twikoo)

  #bber.brevity-feed
    if sliced.length === 0
      .brevity-empty
        i.solitude.fas.fa-inbox
        p 还没有动态，等等再来看吧~
    else
      section.brevity-list
        each item in sliced
          - var permalink = url_for('essay/' + item.id + '/')
          - var anchorId = 'brevity-' + item.id
          article.brevity-item(id=anchorId data-id=item.id data-path=permalink)
            header.brevity-header
              img.brevity-avatar(src=theme.aside.my_card.author.img alt=config.author)
              span.brevity-author= config.author
            .brevity-body
              if item.content
                p.brevity-text= item.content

              if item.image && item.image.length
                - var imgCount = item.image.length
                - var gridClass = (imgCount === 1) ? 'g1' : (imgCount === 2) ? 'g2' : (imgCount === 3) ? 'g3' : (imgCount === 4) ? 'g4' : 'g9'
                .brevity-images(class=gridClass)
                  each img in item.image
                    - var src = (typeof img === 'string') ? img : img.url
                    - var alt = (typeof img === 'string') ? '图片' : (img.alt || '图片')
                    a.brevity-image(href=src target='_blank' rel='noopener')
                      img(src=src alt=alt loading='lazy')

              if item.video
                .brevity-video
                  if item.video.bilibili
                    iframe(src='//player.bilibili.com/player.html?autoplay=0&bvid=' + item.video.bilibili scrolling='no' frameborder='no' allowfullscreen='true')
                  else if item.video.player
                    video(src=item.video.player controls='controls')

              if item.aplayer
                .brevity-music
                  meting-js(server=item.aplayer.server type='song' id=item.aplayer.id mutex='true' preload='none' theme='var(--efu-main)' data-lrctype='0')

              if item.link
                a.brevity-link(href=url_for(item.link) target='_blank' rel='noopener')
                  i.solitude.fas.fa-link
                  span= item.link

            .brevity-foot
              .brevity-meta
                time.brevity-date(datetime=moment(item.date).format())
                  = moment(item.date).format('YYYY-MM-DD HH:mm')
                if item.location
                  span.brevity-location
                    i.solitude.fas.fa-location-dot
                    = ' ' + item.location
              .brevity-actions
                button.brevity-share(type='button' onclick='shareBrevityCard(this)' aria-label='分享为图片')
                  i.solitude.fas.fa-image
                button.brevity-jump(type='button' onclick='jumpToBrevityComments(this)')
                  i.solitude.fas.fa-comment
                  span.brevity-comment-count(data-path=permalink)

            - var hostId = 'twikoo-' + item.id
            .brevity-comments.is-empty(hidden)
              .brevity-comment-host(id=hostId)

      if totalPages > 1
        - var basePath = url_for('essay/')
        - var pageNums = []
        - for (var n = 1; n <= totalPages; n++) pageNums.push(n)
        nav.brevity-pagination
          if currentPage > 1
            - var prevHref = (currentPage - 1 === 1) ? basePath : (basePath + 'page/' + (currentPage - 1) + '/')
            a.brevity-page-link.brevity-page-arrow(href=prevHref aria-label='上一页')
              i.solitude.fas.fa-chevron-left
          each n in pageNums
            if n === currentPage
              span.brevity-page-link.is-current= n
            else
              - var href = (n === 1) ? basePath : (basePath + 'page/' + n + '/')
              a.brevity-page-link(href=href)= n
          if currentPage < totalPages
            - var nextHref = basePath + 'page/' + (currentPage + 1) + '/'
            a.brevity-page-link.brevity-page-arrow(href=nextHref aria-label='下一页')
              i.solitude.fas.fa-chevron-right

    //- 分享卡片模板（隐藏，js 填数据后用 html2canvas 截图）
    #brevityShareTemplate(aria-hidden='true')
      .share-card
        header.share-brand
          img.share-logo(src=url_for(theme.site.icon) crossorigin='anonymous')
          span.share-blogname= config.title
        .share-author-row
          img.share-avatar(src=theme.aside.my_card.author.img alt=config.author crossorigin='anonymous')
          .share-author-info
            span.share-name= config.author
            span.share-date
        .share-divider
        .share-content
        .share-divider
        footer.share-footer
          .share-meta
          .share-qr-row
            .share-qr
            .share-qr-desc
              span 扫码查看完整动态
              span.share-qr-domain= (config.url || '').replace(/^https?:\/\//, '')

    //- 分享预览模态框
    #brevityShareModal(hidden)
      .brevity-share-mask(onclick='closeBrevityShareModal()')
      .brevity-share-window
        .brevity-share-loading
          i.solitude.fas.fa-spinner.fa-spin
          span 正在生成分享图…
        .brevity-share-result(hidden)
          img.brevity-share-img(alt='分享图')
          .brevity-share-tips
            | PC：右键图片 → 另存为；手机：长按图片保存
          .brevity-share-actions
            a.brevity-share-save(download='moments-share.png') 保存图片
            button.brevity-share-close(type='button' onclick='closeBrevityShareModal()') 关闭

    script.
      (function () {
        const TWIKOO_CDN = '!{twikooCdn}';
        const ENV_ID = '!{envId}';
        const REGION = '!{region}';
        const EXTRA = !{JSON.stringify(twikooOption)};
        const inited = new Set();

        function ensureTwikoo() {
          if (typeof twikoo === 'object') return Promise.resolve();
          return utils.getScript(TWIKOO_CDN);
        }

        function fillCounts() {
          const els = document.querySelectorAll('.brevity-comment-count[data-path]');
          if (!els.length || typeof twikoo !== 'object') return;
          const urls = Array.from(els).map(el => el.dataset.path);
          twikoo.getCommentsCount({ envId: ENV_ID, region: REGION, urls: urls, includeReply: false })
            .then(res => {
              els.forEach((el, i) => {
                const c = res[i] ? res[i].count : 0;
                el.textContent = c > 0 ? c : '';
              });
            })
            .catch(() => {});
        }

        ensureTwikoo().then(fillCounts);

        function initCommentsFor(item) {
          const path = item.dataset.path;
          if (!path || inited.has(path)) return;
          inited.add(path);
          const wrap = item.querySelector('.brevity-comments');
          const host = wrap.querySelector('.brevity-comment-host');
          wrap.removeAttribute('hidden');
          ensureTwikoo().then(() => {
            twikoo.init(Object.assign({
              el: '#' + host.id,
              envId: ENV_ID,
              region: REGION,
              path: path,
              onCommentLoaded: () => {
                stripPowerBy(wrap);
                markEmptyState(wrap);
              }
            }, EXTRA));
            // 多次尝试，应付 Twikoo 异步插入
            [200, 800, 2000].forEach(t => setTimeout(() => {
              stripPowerBy(wrap);
              markEmptyState(wrap);
            }, t));
          });
        }

        // 移除 Powered by Twikoo：直接干掉 .tk-footer 整块
        function stripPowerBy(wrap) {
          if (!wrap) return;
          wrap.querySelectorAll('.tk-footer').forEach(el => el.remove());
        }

        // 没评论时给 wrap 加 .is-empty，CSS 配合隐藏空背景
        function markEmptyState(wrap) {
          if (!wrap) return;
          const has = wrap.querySelectorAll('.tk-comment').length > 0;
          wrap.classList.toggle('is-empty', !has);
        }

        // 进入视口时懒加载 Twikoo
        if ('IntersectionObserver' in window) {
          const obs = new IntersectionObserver((entries) => {
            entries.forEach(e => {
              if (e.isIntersecting) {
                initCommentsFor(e.target);
                obs.unobserve(e.target);
              }
            });
          }, { rootMargin: '300px 0px' });
          document.querySelectorAll('.brevity-item').forEach(it => obs.observe(it));
        } else {
          document.querySelectorAll('.brevity-item').forEach(initCommentsFor);
        }

        // 点 💬 按钮：触发 init（若需要）并切换输入栏显示
        window.jumpToBrevityComments = function (btn) {
          const item = btn.closest('.brevity-item');
          initCommentsFor(item);
          const wrap = item.querySelector('.brevity-comments');
          const showing = wrap.classList.toggle('show-input');
          btn.classList.toggle('is-active', showing);
          if (showing) {
            setTimeout(() => {
              const ta = wrap.querySelector('.el-textarea__inner, textarea');
              if (ta && ta.focus) ta.focus();
              wrap.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            }, 200);
          }
        };

        // ============== 分享卡片 ==============
        const HTML2CANVAS_CDN = 'https://fastly.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.min.js';

        function ensureHtml2Canvas() {
          if (typeof html2canvas === 'function') return Promise.resolve();
          return utils.getScript(HTML2CANVAS_CDN);
        }

        window.shareBrevityCard = function (btn) {
          const item = btn.closest('.brevity-item');
          const tpl = document.getElementById('brevityShareTemplate');
          const modal = document.getElementById('brevityShareModal');
          const loading = modal.querySelector('.brevity-share-loading');
          const result = modal.querySelector('.brevity-share-result');
          const imgEl = modal.querySelector('.brevity-share-img');
          const saveLink = modal.querySelector('.brevity-share-save');

          // 显示模态框 + loading
          modal.removeAttribute('hidden');
          loading.removeAttribute('hidden');
          result.setAttribute('hidden', '');

          // 填充模板数据
          tpl.querySelector('.share-date').textContent =
            item.querySelector('.brevity-date')?.textContent || '';
          tpl.querySelector('.share-content').innerHTML = '';
          const text = item.querySelector('.brevity-text');
          if (text) {
            const p = document.createElement('p');
            p.className = 'share-text';
            p.textContent = text.textContent;
            tpl.querySelector('.share-content').appendChild(p);
          }
          const imgs = item.querySelectorAll('.brevity-images img');
          if (imgs.length) {
            const grid = document.createElement('div');
            grid.className = 'share-images g' + (imgs.length === 1 ? '1' : imgs.length === 2 ? '2' : imgs.length <= 4 ? '4' : '9');
            imgs.forEach(im => {
              const clone = im.cloneNode(false);
              clone.setAttribute('crossorigin', 'anonymous');
              grid.appendChild(clone);
            });
            tpl.querySelector('.share-content').appendChild(grid);
          }
          const loc = item.querySelector('.brevity-location');
          tpl.querySelector('.share-meta').textContent = loc ? loc.textContent.trim() : '';

          // 生成二维码：跳到 /essay/ 列表页对应卡片的锚点
          const qrEl = tpl.querySelector('.share-qr');
          qrEl.innerHTML = '';
          const essayBase = '!{url_for("essay/")}';
          const fullUrl = location.origin + essayBase + '#brevity-' + item.dataset.id;
          if (typeof QRCode === 'function') {
            new QRCode(qrEl, { text: fullUrl, width: 90, height: 90, correctLevel: 0 });
          }

          // 渲染截图
          ensureHtml2Canvas().then(() => {
            return html2canvas(tpl.querySelector('.share-card'), {
              backgroundColor: null,
              scale: 2,
              useCORS: true,
              allowTaint: false,
              logging: false
            });
          }).then(canvas => {
            const dataUrl = canvas.toDataURL('image/png');
            imgEl.src = dataUrl;
            saveLink.href = dataUrl;
            saveLink.download = 'moments-' + (item.dataset.id || 'share') + '.png';
            loading.setAttribute('hidden', '');
            result.removeAttribute('hidden');
          }).catch(err => {
            console.error('[brevity-share] render failed:', err);
            loading.innerHTML = '<i class="solitude fas fa-circle-exclamation"></i><span>生成失败：' + (err.message || '未知错误') + '</span>';
          });
        };

        window.closeBrevityShareModal = function () {
          const modal = document.getElementById('brevityShareModal');
          modal.setAttribute('hidden', '');
        };
      })();
