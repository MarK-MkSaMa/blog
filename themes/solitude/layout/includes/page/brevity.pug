include ../widgets/page/banner
if theme.brevity.enable
  - var feed = site.data.brevity || []
  - var stripCount = theme.brevity.strip
  - var sliced = (stripCount === -1) ? feed : feed.slice(0, stripCount)
  - var envId = theme.twikoo.envId
  - var region = theme.twikoo.region || ''
  - var twikooOption = theme.twikoo.option || {}
  - var twikooCdn = url_for(theme.cdn.twikoo)

  #bber.brevity-feed
    if sliced.length === 0
      .brevity-empty
        i.solitude.fas.fa-inbox
        p 还没有动态，等等再来看吧~
    else
      section.brevity-list
        each item in sliced
          - var permalink = url_for('essay/' + item.id + '/')
          article.brevity-item(data-id=item.id data-path=permalink)
            header.brevity-header
              img.brevity-avatar(src=theme.aside.my_card.author.img alt=config.author)
              span.brevity-author= config.author
            .brevity-body
              if item.content
                p.brevity-text= item.content

              if item.image && item.image.length
                - var imgCount = item.image.length
                - var gridClass = (imgCount === 1) ? 'g1' : (imgCount === 2) ? 'g2' : (imgCount === 3) ? 'g3' : (imgCount === 4) ? 'g4' : 'g9'
                .brevity-images(class=gridClass)
                  each img in item.image
                    - var src = (typeof img === 'string') ? img : img.url
                    - var alt = (typeof img === 'string') ? '图片' : (img.alt || '图片')
                    a.brevity-image(href=src target='_blank' rel='noopener')
                      img(src=src alt=alt loading='lazy')

              if item.video
                .brevity-video
                  if item.video.bilibili
                    iframe(src='//player.bilibili.com/player.html?autoplay=0&bvid=' + item.video.bilibili scrolling='no' frameborder='no' allowfullscreen='true')
                  else if item.video.player
                    video(src=item.video.player controls='controls')

              if item.aplayer
                .brevity-music
                  meting-js(server=item.aplayer.server type='song' id=item.aplayer.id mutex='true' preload='none' theme='var(--efu-main)' data-lrctype='0')

              if item.link
                a.brevity-link(href=url_for(item.link) target='_blank' rel='noopener')
                  i.solitude.fas.fa-link
                  span= item.link

            .brevity-foot
              .brevity-meta
                time.brevity-date(datetime=moment(item.date).format())
                  = moment(item.date).format('YYYY-MM-DD HH:mm')
                if item.location
                  span.brevity-location
                    i.solitude.fas.fa-location-dot
                    = ' ' + item.location
              button.brevity-jump(type='button' onclick='jumpToBrevityComments(this)')
                i.solitude.fas.fa-comment
                span.brevity-comment-count(data-path=permalink)

            - var hostId = 'twikoo-' + item.id
            .brevity-comments(hidden)
              .brevity-comment-host(id=hostId)

      if stripCount !== -1 && feed.length > stripCount
        #bber-tips= _p('essay.tip1').replace('#{count}', stripCount)

    script.
      (function () {
        const TWIKOO_CDN = '!{twikooCdn}';
        const ENV_ID = '!{envId}';
        const REGION = '!{region}';
        const EXTRA = !{JSON.stringify(twikooOption)};
        const inited = new Set();

        function ensureTwikoo() {
          if (typeof twikoo === 'object') return Promise.resolve();
          return utils.getScript(TWIKOO_CDN);
        }

        function fillCounts() {
          const els = document.querySelectorAll('.brevity-comment-count[data-path]');
          if (!els.length || typeof twikoo !== 'object') return;
          const urls = Array.from(els).map(el => el.dataset.path);
          twikoo.getCommentsCount({ envId: ENV_ID, region: REGION, urls: urls, includeReply: false })
            .then(res => {
              els.forEach((el, i) => {
                const c = res[i] ? res[i].count : 0;
                el.textContent = c > 0 ? c : '';
              });
            })
            .catch(() => {});
        }

        ensureTwikoo().then(fillCounts);

        function initCommentsFor(item) {
          const path = item.dataset.path;
          if (!path || inited.has(path)) return;
          inited.add(path);
          const wrap = item.querySelector('.brevity-comments');
          const host = wrap.querySelector('.brevity-comment-host');
          wrap.removeAttribute('hidden');
          ensureTwikoo().then(() => {
            twikoo.init(Object.assign({
              el: '#' + host.id,
              envId: ENV_ID,
              region: REGION,
              path: path,
              onCommentLoaded: () => stripPowerBy(wrap)
            }, EXTRA));
            // 多次尝试，应付 Twikoo 异步插入
            [200, 800, 2000].forEach(t => setTimeout(() => stripPowerBy(wrap), t));
          });
        }

        // 移除 Powered by Twikoo：直接干掉 .tk-footer 整块
        function stripPowerBy(wrap) {
          if (!wrap) return;
          wrap.querySelectorAll('.tk-footer').forEach(el => el.remove());
        }

        // 进入视口时懒加载 Twikoo
        if ('IntersectionObserver' in window) {
          const obs = new IntersectionObserver((entries) => {
            entries.forEach(e => {
              if (e.isIntersecting) {
                initCommentsFor(e.target);
                obs.unobserve(e.target);
              }
            });
          }, { rootMargin: '300px 0px' });
          document.querySelectorAll('.brevity-item').forEach(it => obs.observe(it));
        } else {
          document.querySelectorAll('.brevity-item').forEach(initCommentsFor);
        }

        // 点 💬 按钮：触发 init（若需要）并切换输入栏显示
        window.jumpToBrevityComments = function (btn) {
          const item = btn.closest('.brevity-item');
          initCommentsFor(item);
          const wrap = item.querySelector('.brevity-comments');
          const showing = wrap.classList.toggle('show-input');
          btn.classList.toggle('is-active', showing);
          if (showing) {
            setTimeout(() => {
              const ta = wrap.querySelector('.el-textarea__inner, textarea');
              if (ta && ta.focus) ta.focus();
              wrap.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            }, 200);
          }
        };
      })();
