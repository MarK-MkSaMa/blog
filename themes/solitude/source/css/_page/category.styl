// ============================================================
// 分类页 — 顶部 header 全宽 + 双栏（左树 / 右文章）
// ============================================================

#categories-page
  display grid
  grid-template-columns 220px 1fr
  grid-template-areas \
    'header header' \
    'sidebar main'
  gap 1.2rem 1.5rem
  width 100%
  align-items start

  +maxWidth768()
    grid-template-columns 1fr
    grid-template-areas \
      'header' \
      'sidebar' \
      'main'
    gap 1rem

  // ---------- 顶部全宽 header ----------
  .cat-page-header
    grid-area header
    padding-bottom .9rem
    border-bottom 1px dashed var(--efu-theme-op)

  .cat-breadcrumb
    display flex
    align-items center
    gap .35rem
    font-size .8rem
    color var(--efu-secondtext)
    margin-bottom .5rem
    flex-wrap wrap

    .cat-bc-link
      color var(--efu-secondtext)
      text-decoration none
      transition color .2s

      &:hover
        color var(--efu-main)

    .cat-bc-sep
      opacity .5

  .cat-title
    margin 0 0 .35rem
    font-size 1.6rem
    font-weight 700
    color var(--efu-fontcolor)

  .cat-meta
    margin 0
    font-size .85rem
    color var(--efu-secondtext)

  .cat-meta-count
    color var(--efu-main)
    font-weight 600

  // ---------- 左：分类树 ----------
  .cat-sidebar
    grid-area sidebar
    position sticky
    top 5rem
    background var(--efu-card-bg)
    border var(--style-border-always)
    border-radius 12px
    padding .9rem .6rem
    max-height calc(100vh - 6rem)
    overflow-y auto

    +maxWidth768()
      position static
      max-height none

  .cat-sidebar-header
    font-size .8rem
    color var(--efu-secondtext)
    padding 0 .6rem .5rem
    letter-spacing .1em
    text-transform uppercase

  .cat-sidebar ul
    list-style none
    padding 0
    margin 0

  .cat-tree-children
    display none
    overflow hidden

  // 当前路径上的祖先节点：展开子树
  .cat-sidebar li.is-expanded > .cat-tree-children
    display block
    animation cat-tree-slide .25s ease-out

  @keyframes cat-tree-slide
    from
      opacity 0
      transform translateY(-4px)
    to
      opacity 1
      transform translateY(0)

  .cat-tree-link
    display flex
    align-items center
    gap .5rem
    padding .45rem .85rem
    border-radius 8px
    color var(--efu-fontcolor)
    font-size .9rem
    text-decoration none
    transition background .2s, color .2s
    cursor pointer

    &:hover
      background var(--efu-gray-op)
      color var(--efu-main)

    &.is-current
      background var(--efu-main)
      color #fff

      .cat-tree-count
        background rgba(255, 255, 255, .25)
        color #fff

    &.is-ancestor
      color var(--efu-main)
      font-weight 600

    i
      font-size .8rem
      flex-shrink 0

    .cat-tree-name
      flex 1
      overflow hidden
      text-overflow ellipsis
      white-space nowrap

    .cat-tree-count
      font-size .72rem
      padding 1px 7px
      border-radius 99px
      background var(--efu-gray-op)
      color var(--efu-secondtext)
      font-weight 500

  .cat-tree-divider
    height 1px
    background rgba(125, 125, 125, .15)
    margin .55rem .6rem

  // ---------- 右：主内容区 ----------
  .cat-main
    grid-area main
    min-width 0

  .cat-empty
    text-align center
    padding 4rem 1rem
    color var(--efu-secondtext)

    i
      display block
      font-size 2.5rem
      opacity .35
      margin-bottom .8rem

    p
      margin 0
      font-size .9rem

  // ---------- 文章卡片 ----------
  .cat-post-list
    list-style none
    margin 0
    padding 0
    display flex
    flex-direction column
    gap .8rem

  .cat-post-list.is-fading-in .cat-post-row:not(.is-hidden)
    animation cat-post-fadein .35s ease-out

  @keyframes cat-post-fadein
    from
      opacity 0
      transform translateY(6px)
    to
      opacity 1
      transform translateY(0)

  .cat-post-row
    background var(--efu-card-bg)
    border var(--style-border-always)
    border-radius 12px
    overflow hidden
    min-height 100px
    transition border .25s, box-shadow .25s

    &:hover
      border var(--style-border-hover)
      box-shadow var(--efu-shadow-border)

    &.is-hidden
      display none

    +maxWidth768()
      min-height 0

  .cat-post-link
    display flex
    align-items stretch
    gap 0
    padding 0
    color inherit
    text-decoration none
    height 100%

    +maxWidth768()
      flex-direction column

  // 横向矩形封面：宽度按 % 占比，高度跟随行高自动拉伸（避免下方黑边）
  .cat-post-cover
    flex 0 0 38%
    align-self stretch
    overflow hidden
    background var(--efu-gray-op)

    +maxWidth1300()
      flex 0 0 40%

    +maxWidth768()
      flex 0 0 auto
      width 100%
      height 140px
      align-self auto

    img
      width 100%
      height 100%
      object-fit cover
      display block
      transition transform .3s

  .cat-post-row:hover .cat-post-cover img
    transform scale(1.04)

  .cat-post-info
    flex 1 1 100%
    min-width 0
    padding .7rem 1.2rem
    display flex
    flex-direction column
    gap .3rem
    justify-content center

    +maxWidth768()
      padding .8rem 1rem
      gap .3rem

  .cat-post-title
    margin 0
    font-size 1.05rem
    font-weight 600
    color var(--efu-fontcolor)
    line-height 1.4
    overflow hidden
    text-overflow ellipsis
    display -webkit-box
    -webkit-line-clamp 2
    -webkit-box-orient vertical

    +maxWidth768()
      font-size .95rem

  .cat-post-cats
    display inline-flex
    align-items center
    gap .25rem
    font-size .76rem
    color var(--efu-main)
    flex-wrap wrap

    .cat-post-cat
      font-weight 500

    .cat-post-cat-sep
      opacity .55

  .cat-post-tags
    display flex
    flex-wrap wrap
    gap .35rem

    .cat-post-tag
      font-size .72rem
      padding 1px 8px
      border-radius 99px
      background var(--efu-gray-op)
      color var(--efu-secondtext)

  .cat-post-date
    margin-top auto
    font-size .72rem
    color var(--efu-secondtext)
    opacity .85
