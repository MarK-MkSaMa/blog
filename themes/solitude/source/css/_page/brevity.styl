// ============================================================
// 朋友圈页 — 单列时间流 + 九宫格 + 内嵌评论
// ============================================================

if hexo-config('brevity.home_mini')
  #bbTimeList
    background var(--efu-card-bg)
    border-radius 12px
    display flex
    white-space nowrap
    overflow hidden
    border var(--style-border)
    transition .3s
    height 50px
    width 100%
    justify-content space-between
    user-select none
    align-items center
    padding .5rem 1rem
    animation slide-in .6s 0s backwards
    margin-bottom .5rem

    &.more-page
      margin-bottom 0

    +minWidth1300()
      &:hover
        border var(--style-border-hover)
        box-shadow var(--efu-shadow-main)

    +maxWidth768()
      margin 0
      background var(--efu-background)
      border none
      padding 0 .2rem

  i.bber-logo,
  i.bber-gotobb
    transition .3s
    cursor pointer

    &:hover
      opacity .8
      color var(--efu-theme)

  i.bber-logo
    font-size 1.2rem
    margin-right 1rem

  i.bber-gotobb
    font-size 16px
    margin-left 1rem

  #bber-talk
    width 100%
    height 25px
    line-height 25px
    display flex
    flex-direction column

    .li-style
      width auto
      max-width 100%
      height 25px
      text-align center
      overflow hidden
      text-overflow ellipsis
      transition .3s
      align-items center
      font-weight 700
      margin auto
      cursor pointer
      white-space nowrap

      .solitude
        font-size 1rem
        margin-left .5rem

  #bbtalk
    overflow hidden
    width 100%
    text-overflow ellipsis
    white-space nowrap

  #bbTimeList
    .li-style
      &:hover
        color var(--efu-theme)
        transition .3s

if hexo-config('brevity.enable')
  #bber.brevity-feed
    max-width 640px
    margin 0 auto
    width 100%

    .brevity-empty
      text-align center
      padding 4rem 1rem
      color var(--efu-secondtext)

      i
        display block
        font-size 2.5rem
        opacity .4
        margin-bottom .8rem

      p
        margin 0
        font-size .9rem

    .brevity-list
      display flex
      flex-direction column
      gap .8rem

    .brevity-item
      background var(--efu-card-bg)
      border var(--style-border-always)
      border-radius 12px
      padding 1rem 1.2rem
      transition border .25s

      &:hover
        border var(--style-border-hover)

    .brevity-text
      margin 0
      font-size .94rem
      line-height 1.7
      color var(--efu-fontcolor)
      white-space pre-wrap
      word-break break-word

    .brevity-images
      display grid
      gap 4px
      margin-top .7rem

      a.brevity-image
        display block
        position relative
        aspect-ratio 1 / 1
        overflow hidden
        border-radius 8px
        background var(--efu-gray-op)

        img
          width 100%
          height 100%
          object-fit cover
          display block
          transition transform .35s

        &:hover img
          transform scale(1.04)

      &.g1
        grid-template-columns 1fr
        max-width 380px

        a.brevity-image
          aspect-ratio auto
          max-height 460px
          background transparent

          img
            object-fit contain
            width 100%
            height auto
            max-height 460px

      &.g2
        grid-template-columns repeat(2, 1fr)
        max-width 420px

      &.g3, &.g9
        grid-template-columns repeat(3, 1fr)

      &.g4
        grid-template-columns repeat(2, 1fr)
        max-width 420px

    .brevity-video
      position relative
      margin-top .7rem
      aspect-ratio 16 / 9
      border-radius 10px
      overflow hidden
      border var(--style-border)

      iframe,
      video
        position absolute
        inset 0
        width 100%
        height 100%
        border 0

    .brevity-music
      margin-top .7rem
      border-radius 10px
      overflow hidden
      border var(--style-border-always)
      background var(--efu-secondbg)

      .aplayer
        margin 0

        .aplayer-body
          background-color var(--efu-card-bg)

    .brevity-link
      display inline-flex
      align-items center
      gap .4rem
      margin-top .7rem
      padding .35rem .8rem
      background var(--efu-gray-op)
      border-radius 8px
      font-size .8rem
      color var(--efu-secondtext)
      transition .25s
      max-width 100%
      overflow hidden
      text-overflow ellipsis
      white-space nowrap

      &:hover
        background var(--efu-main)
        color var(--efu-white)

      i
        font-size .78rem

    .brevity-foot
      display flex
      justify-content space-between
      align-items center
      margin-top .8rem
      font-size .75rem

    .brevity-meta
      display inline-flex
      align-items center
      gap .5rem
      color var(--efu-secondtext)

    .brevity-location
      display inline-flex
      align-items center
      gap .25rem

      i
        font-size .68rem

    .brevity-toggle
      display inline-flex
      align-items center
      gap .35rem
      padding .3rem .7rem
      border-radius 99px
      background transparent
      border none
      cursor pointer
      color var(--efu-secondtext)
      font-size .78rem
      line-height 1
      transition .2s

      &:hover
        background var(--efu-gray-op)
        color var(--efu-fontcolor)

      &[aria-expanded="true"]
        background var(--efu-main)
        color var(--efu-white)

      i
        font-size .82rem

      .brevity-comment-count:empty
        display none

    .brevity-comments
      margin-top .8rem
      padding .85rem 1rem
      background var(--efu-secondbg)
      border-radius 10px

      &[hidden]
        display none

      .brevity-comment-host
        min-height 40px

    +maxWidth768()
      .brevity-item
        padding .85rem 1rem

      .brevity-foot
        font-size .72rem

  #bber-tips
    text-align center
    margin-top 1.5rem
    font-size .8rem
    color var(--efu-secondtext)
