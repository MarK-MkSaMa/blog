// ============================================================
// 朋友圈页 — 单列时间流 + 九宫格 + 内嵌评论
// ============================================================

if hexo-config('brevity.home_mini')
  #bbTimeList
    background var(--efu-card-bg)
    border-radius 12px
    display flex
    white-space nowrap
    overflow hidden
    border var(--style-border)
    transition .3s
    height 50px
    width 100%
    justify-content space-between
    user-select none
    align-items center
    padding .5rem 1rem
    animation slide-in .6s 0s backwards
    margin-bottom .5rem

    &.more-page
      margin-bottom 0

    +minWidth1300()
      &:hover
        border var(--style-border-hover)
        box-shadow var(--efu-shadow-main)

    +maxWidth768()
      margin 0
      background var(--efu-background)
      border none
      padding 0 .2rem

  i.bber-logo,
  i.bber-gotobb
    transition .3s
    cursor pointer

    &:hover
      opacity .8
      color var(--efu-theme)

  i.bber-logo
    font-size 1.2rem
    margin-right 1rem

  i.bber-gotobb
    font-size 16px
    margin-left 1rem

  #bber-talk
    width 100%
    height 25px
    line-height 25px
    display flex
    flex-direction column

    .li-style
      width auto
      max-width 100%
      height 25px
      text-align center
      overflow hidden
      text-overflow ellipsis
      transition .3s
      align-items center
      font-weight 700
      margin auto
      cursor pointer
      white-space nowrap

      .solitude
        font-size 1rem
        margin-left .5rem

  #bbtalk
    overflow hidden
    width 100%
    text-overflow ellipsis
    white-space nowrap

  #bbTimeList
    .li-style
      &:hover
        color var(--efu-theme)
        transition .3s

if hexo-config('brevity.enable')
  // banner 右下角名字 + 头像（仿微信朋友圈封面页）
  .author-content.sharePage
    position relative

  .brevity-banner-profile
    position absolute
    right 1.5rem
    bottom 1rem
    display flex
    align-items center
    gap .8rem
    z-index 2
    pointer-events none

  .brevity-banner-name
    font-size 1.25rem
    font-weight 600
    color #fff
    text-shadow 0 1px 4px rgba(0, 0, 0, .55)
    letter-spacing .02em

  .brevity-banner-avatar
    width 64px
    height 64px
    border-radius 8px
    object-fit cover
    box-shadow 0 2px 12px rgba(0, 0, 0, .4)

  +maxWidth768()
    .brevity-banner-profile
      right 1rem
      bottom .8rem
      gap .55rem

    .brevity-banner-name
      font-size 1rem

    .brevity-banner-avatar
      width 48px
      height 48px

  #bber.brevity-feed
    max-width 640px
    margin 0 auto
    width 100%

    .brevity-empty
      text-align center
      padding 4rem 1rem
      color var(--efu-secondtext)

      i
        display block
        font-size 2.5rem
        opacity .4
        margin-bottom .8rem

      p
        margin 0
        font-size .9rem

    .brevity-list
      display flex
      flex-direction column
      gap .8rem

    .brevity-item
      background var(--efu-card-bg)
      border var(--style-border-always)
      border-radius 12px
      padding 1rem 1.2rem
      transition border .25s

      &:hover
        border var(--style-border-hover)

    .brevity-header
      display flex
      align-items center
      gap .65rem
      margin-bottom .7rem

    .brevity-avatar
      width 38px
      height 38px
      border-radius 50%
      object-fit cover
      flex-shrink 0
      border var(--style-border-always)

    .brevity-author
      font-weight 600
      font-size .92rem
      color var(--efu-main)
      letter-spacing .01em

    .brevity-text
      margin 0
      font-size .94rem
      line-height 1.7
      color var(--efu-fontcolor)
      white-space pre-wrap
      word-break break-word

    .brevity-images
      display grid
      gap 4px
      margin-top .7rem

      a.brevity-image
        display block
        position relative
        aspect-ratio 1 / 1
        overflow hidden
        border-radius 8px
        background var(--efu-gray-op)

        img
          width 100%
          height 100%
          object-fit cover
          display block
          transition transform .35s

        &:hover img
          transform scale(1.04)

      &.g1
        grid-template-columns 1fr
        max-width 380px

        a.brevity-image
          aspect-ratio auto
          max-height 460px
          background transparent

          img
            object-fit contain
            width 100%
            height auto
            max-height 460px

      &.g2
        grid-template-columns repeat(2, 1fr)
        max-width 420px

      &.g3, &.g9
        grid-template-columns repeat(3, 1fr)

      &.g4
        grid-template-columns repeat(2, 1fr)
        max-width 420px

    .brevity-video
      position relative
      margin-top .7rem
      aspect-ratio 16 / 9
      border-radius 10px
      overflow hidden
      border var(--style-border)

      iframe,
      video
        position absolute
        inset 0
        width 100%
        height 100%
        border 0

    .brevity-music
      margin-top .7rem
      border-radius 10px
      overflow hidden
      border var(--style-border-always)
      background var(--efu-secondbg)

      .aplayer
        margin 0

        .aplayer-body
          background-color var(--efu-card-bg)

    .brevity-link
      display inline-flex
      align-items center
      gap .4rem
      margin-top .7rem
      padding .35rem .8rem
      background var(--efu-gray-op)
      border-radius 8px
      font-size .8rem
      color var(--efu-secondtext)
      transition .25s
      max-width 100%
      overflow hidden
      text-overflow ellipsis
      white-space nowrap

      &:hover
        background var(--efu-main)
        color var(--efu-white)

      i
        font-size .78rem

    .brevity-foot
      display flex
      justify-content space-between
      align-items center
      margin-top .8rem
      font-size .75rem

    .brevity-meta
      display inline-flex
      align-items center
      gap .5rem
      color var(--efu-secondtext)

    .brevity-location
      display inline-flex
      align-items center
      gap .25rem

      i
        font-size .68rem

    .brevity-actions
      display inline-flex
      align-items center
      gap .25rem

    .brevity-jump,
    .brevity-share
      display inline-flex
      align-items center
      gap .35rem
      padding .3rem .7rem
      border-radius 99px
      background transparent
      border none
      cursor pointer
      color var(--efu-secondtext)
      font-size .78rem
      line-height 1
      transition .2s

      &:hover
        background var(--efu-gray-op)
        color var(--efu-fontcolor)

      i
        font-size .82rem

    .brevity-jump
      &.is-active
        background var(--efu-main)
        color var(--efu-white)

      .brevity-comment-count:empty
        display none

    .brevity-comments
      margin-top .8rem
      padding .4rem .9rem
      background var(--efu-secondbg)
      border-radius 10px

      &[hidden]
        display none

      // 没评论 + 没在写评论 → 完全隐藏，避免空背景条
      &.is-empty:not(.show-input)
        display none

      .brevity-comment-host
        min-height 0

      // 取消 Twikoo 容器自带的 padding/margin，避免上下出现大空白
      .tk-comments-container
        padding 0 !important
        margin 0 !important
        min-height 0 !important

      // 最后一条评论去掉 margin-bottom（Solitude 默认给 .5rem）
      .tk-comments-container > .tk-comment:last-child
        margin-bottom 0 !important
        padding-bottom 0 !important

      // 默认隐藏输入表单
      // Twikoo 结构：.tk-comments > [输入表单, .tk-comments-container（列表）]
      // 隐藏 .tk-comments 的直接子元素中 不是 列表（.tk-comments-container）的全部
      // 点击 💬 → 切换 .show-input 类 → 输入栏才出现
      &:not(.show-input) .tk-comments > *:not(.tk-comments-container)
        display none

      // 评论显示精简
      font-size .82rem

      // 隐藏头像
      .tk-avatar,
      img.tk-avatar-img
        display none !important

      .tk-meta,
      .tk-content
        margin-left 0 !important
        padding-left 0 !important

      // 隐藏设备 / 浏览器 / 标签
      .tk-extras,
      .tk-extra,
      .tk-tag,
      .tk-tag-green,
      .tk-tag-yellow,
      .tk-tag-red
        display none !important

      // 隐藏 Twikoo 评论数标题（已在 💬 按钮显示）
      .tk-comments-title
        display none !important

      // 隐藏齿轮（管理员入口 / 私密评论触发）
      .tk-action .tk-action-link:first-child
        display none !important

      // 隐藏 Powered by Twikoo（footer 整块，无视短暂闪现）
      .tk-footer
        display none !important

      // 评论正文 / 昵称 / 时间 字号收紧
      .tk-content,
      .tk-content p
        font-size .82rem !important
        line-height 1.6 !important

      .tk-nick
        font-size .85rem !important
        line-height 1.4 !important

      .tk-time
        font-size .68rem !important

      // 评论项不单独成卡（覆盖 Solitude 默认的 border + 阴影 + 大 padding）
      // 所有评论共用 .brevity-comments 的灰底背景
      .tk-comments-container > .tk-comment
        background transparent !important
        border none !important
        box-shadow none !important
        border-radius 0 !important
        padding .45rem 0 !important
        margin 0 !important
        border-top 1px dashed var(--efu-theme-op) !important

      .tk-comments-container > .tk-comment:first-child
        border-top none !important
        padding-top 0 !important

      // 嵌套回复也去除卡片样式
      .tk-replies > .tk-comment
        background transparent !important
        border none !important
        box-shadow none !important
        border-radius 0 !important
        padding .3rem 0 0 .8rem !important
        margin 0 !important

    +maxWidth768()
      .brevity-item
        padding .85rem 1rem

      .brevity-foot
        font-size .72rem

  #bber-tips
    text-align center
    margin-top 1.5rem
    font-size .8rem
    color var(--efu-secondtext)

  // ============== 朋友圈分页 ==============
  .brevity-pagination
    display flex
    justify-content center
    align-items center
    gap .35rem
    margin 1.6rem auto 0
    flex-wrap wrap

  .brevity-page-link
    display inline-flex
    align-items center
    justify-content center
    min-width 34px
    height 34px
    padding 0 .55rem
    border-radius 8px
    background var(--efu-card-bg)
    border var(--style-border-always)
    color var(--efu-fontcolor)
    font-size .85rem
    text-decoration none
    transition border .25s, background .25s, color .25s

    &:hover
      border var(--style-border-hover)
      color var(--efu-main)

    &.is-current
      background var(--efu-main)
      border-color var(--efu-main)
      color #fff
      cursor default

    &.brevity-page-arrow i
      font-size .75rem

  // ============== 分享卡片模板（截图源） ==============
  // 隐藏在视口外，html2canvas 截图时仍能正确渲染
  #brevityShareTemplate
    position fixed
    left -99999px
    top 0
    z-index -1
    pointer-events none

    .share-card
      width 720px
      box-sizing border-box
      padding 36px 40px
      background #1c1f24
      color #e8eaed
      font-family -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC", "Microsoft YaHei", sans-serif
      line-height 1.6

    .share-brand
      display flex
      align-items center
      gap 10px
      margin-bottom 24px

      .share-logo
        width 28px
        height 28px
        border-radius 6px
        object-fit cover

      .share-blogname
        font-size 17px
        font-weight 600
        letter-spacing .02em

    .share-author-row
      display flex
      align-items center
      gap 14px
      margin-bottom 20px

      .share-avatar
        width 56px
        height 56px
        border-radius 12px
        object-fit cover

      .share-author-info
        display flex
        flex-direction column
        gap 4px

      .share-name
        font-size 18px
        font-weight 600
        color #6b88ff

      .share-date
        font-size 13px
        color #9aa0a6

    .share-divider
      height 1px
      background rgba(255,255,255,.08)
      margin 16px 0

    .share-content
      .share-text
        margin 0 0 14px 0
        font-size 17px
        line-height 1.75
        white-space pre-wrap
        word-break break-word
        color #e8eaed

      .share-images
        display grid
        gap 6px
        margin-top 8px

        img
          width 100%
          aspect-ratio 1 / 1
          object-fit cover
          border-radius 8px
          display block

        &.g1
          grid-template-columns 1fr
          max-width 480px

          img
            aspect-ratio auto
            max-height 480px
            object-fit cover

        &.g2
          grid-template-columns repeat(2, 1fr)
          max-width 480px

        &.g4
          grid-template-columns repeat(2, 1fr)
          max-width 480px

        &.g9
          grid-template-columns repeat(3, 1fr)

    .share-footer
      .share-meta
        font-size 13px
        color #9aa0a6
        margin-bottom 16px
        min-height 1em

      .share-meta:empty
        display none

      .share-qr-row
        display flex
        align-items center
        gap 16px

        .share-qr
          width 90px
          height 90px
          background #fff
          padding 6px
          border-radius 8px
          flex-shrink 0

          canvas, img
            width 100% !important
            height 100% !important
            display block

        .share-qr-desc
          display flex
          flex-direction column
          gap 6px
          font-size 14px
          color #c3c7cc

          .share-qr-domain
            color #6b88ff
            font-weight 600

  // ============== 分享预览模态框 ==============
  #brevityShareModal
    position fixed
    inset 0
    z-index 9999
    display flex
    align-items center
    justify-content center

    &[hidden]
      display none

    .brevity-share-mask
      position absolute
      inset 0
      background rgba(0, 0, 0, .65)
      backdrop-filter blur(4px)
      -webkit-backdrop-filter blur(4px)

    .brevity-share-window
      position relative
      max-width 90vw
      max-height 92vh
      padding 1.2rem
      background var(--efu-card-bg)
      border var(--style-border-always)
      border-radius 16px
      box-shadow 0 12px 40px rgba(0, 0, 0, .45)
      display flex
      flex-direction column
      align-items center
      gap 1rem
      overflow auto

    .brevity-share-loading
      display flex
      flex-direction column
      align-items center
      gap 1rem
      padding 3rem 2rem
      color var(--efu-secondtext)
      font-size .9rem

      i
        font-size 2rem
        color var(--efu-main)

      &[hidden]
        display none

    .brevity-share-result
      display flex
      flex-direction column
      align-items center
      gap 1rem

      &[hidden]
        display none

    .brevity-share-img
      max-width 360px
      max-height 75vh
      width auto
      height auto
      border-radius 12px
      box-shadow 0 6px 24px rgba(0, 0, 0, .35)

    .brevity-share-tips
      font-size .78rem
      color var(--efu-secondtext)
      text-align center

    .brevity-share-actions
      display flex
      gap .8rem

      .brevity-share-save,
      .brevity-share-close
        display inline-flex
        align-items center
        padding .55rem 1.4rem
        border-radius 999px
        font-size .85rem
        font-weight 500
        cursor pointer
        transition .2s
        border none
        text-decoration none

      .brevity-share-save
        background var(--efu-main)
        color #fff

        &:hover
          opacity .85

      .brevity-share-close
        background var(--efu-gray-op)
        color var(--efu-fontcolor)

        &:hover
          background var(--efu-secondbg)
